@model List<Product>

@{
    ViewBag.Title = "All Products";
    Layout = "_Layout";
}

<h2>Products</h2>

@if (TempData["success"] != null)
{
<div class="alert alert-success" role="alert">
    @TempData["success"]
</div>
}

<!-- Search and Filter Form -->
<form class="container mb-3">
    <div class="row">
        <div class="col-md-4">
            <input type="text" id="searchQuery" class="form-control" placeholder="Search by name" value="@ViewBag.SearchQuery">
        </div>
        <div class="col-md-3">
            <select id="categoryFilter" class="form-control">
                <option value="">All Categories</option>
                @foreach (var category in ViewBag.Categories as SelectList)
                {
                    <option value="@category.Value" selected="@(ViewBag.SelectedCategory != null && ViewBag.SelectedCategory.ToString() == category.Value ? "selected" : null)">
                        @category.Text
                    </option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <select id="sortBy" class="form-control">
                <option value="">Sort By</option>
                <option value="price_asc" selected="@(ViewBag.SortBy == "price_asc" ? "selected" : null)">Price (Low to High)</option>
                <option value="price_desc" selected="@(ViewBag.SortBy == "price_desc" ? "selected" : null)">Price (High to Low)</option>
                <option value="name_asc" selected="@(ViewBag.SortBy == "name_asc" ? "selected" : null)">Name (A-Z)</option>
                <option value="name_desc" selected="@(ViewBag.SortBy == "name_desc" ? "selected" : null)">Name (Z-A)</option>
            </select>
        </div>
    </div>
</form>

<!-- Product List -->
<div id="productList">
    @await Html.PartialAsync("_ProductList", Model)
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        function fetchProducts() {
            var searchQuery = $("#searchQuery").val();
            var categoryId = $("#categoryFilter").val();
            var sortBy = $("#sortBy").val();

            $.ajax({
                url: '@Url.Action("FilterProducts", "Product")',
                type: 'GET',
                data: { searchQuery: searchQuery, categoryId: categoryId, sortBy: sortBy },
                beforeSend: function() {
                    $("#productList").html("<p>Loading...</p>");
                },
                success: function (result) {
                    $("#productList").html(result);
                }
            });
        }

        // Trigger on input change
        $("#searchQuery, #categoryFilter, #sortBy").on("input change", fetchProducts);
    });
</script>
