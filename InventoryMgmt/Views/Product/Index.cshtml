@model List<Product>

@{
    ViewBag.Title = "All Products";
    Layout = "_Layout";
}

<h2>Products</h2>

<!-- Search and Filter Form -->
<form method="get" class="mb-3">
    <div class="row">
        <div class="col-md-4">
            <input type="text" name="searchQuery" class="form-control" placeholder="Search by name" value="@ViewBag.SearchQuery">
        </div>
        <div class="col-md-3">
            <select name="categoryId" class="form-control">
                <option value="">All Categories</option>
                @foreach (var category in ViewBag.Categories as SelectList)
                {
                    <option value="@category.Value" selected="@(ViewBag.SelectedCategory == int.Parse(category.Value) ? "selected" : null)">
                        @category.Text
                    </option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <select name="sortBy" class="form-control">
                <option value="">Sort By</option>
                <option value="price_asc" selected="@(ViewBag.SortBy == "price_asc" ? "selected" : null)">Price (Low to High)</option>
                <option value="price_desc" selected="@(ViewBag.SortBy == "price_desc" ? "selected" : null)">Price (High to Low)</option>
                <option value="name_asc" selected="@(ViewBag.SortBy == "name_asc" ? "selected" : null)">Name (A-Z)</option>
                <option value="name_desc" selected="@(ViewBag.SortBy == "name_desc" ? "selected" : null)">Name (Z-A)</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Apply</button>
        </div>
    </div>
</form>

@if (Model.Any())
{
    <div class="container">
        <div class="row">
            @foreach (var product in Model)
            {
                <div class="col-md-3 mb-2">
                    <div class="card shadow">
                        <div class="card-body">
                            <h5 class="card-title">@product.ProductName</h5>
                            <h6 class="card-subtitle mb-2 text-muted">Category: @product.Category.Name</h6>
                            <p class="card-text">
                                Price: <strong>@product.Price.ToString("C")</strong><br>
                                Quantity: <strong>@product.Quantity</strong><br>
                            </p>
                            <a asp-action="View" asp-route-id="@product.ProductId" class="btn btn-primary">View</a>
                            @if (product.Quantity == 0)
                            { 
                                <a href="#" class="btn btn-success disabled">Add to Order</a>
                            }
                            else
                            { 
                                <a href="#" class="btn btn-success">Add to Order</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <p>There are currently no products to display. <a asp-action="Add">Add a Product</a></p>
}
