@inject SignInManager<IdentityUser> SignInManager

<nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
    <div class="container-fluid">
        <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">InventoryMgmt</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
            <!-- LEFT SIDE NAV LINKS -->
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-dark" asp-area="ProductManagement" asp-controller="Product" asp-action="Index">Products</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-dark" asp-area="ProductManagement" asp-controller="Category" asp-action="Index">Categories</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-dark" asp-area="ProductManagement" asp-controller="Cart" asp-action="Index">Cart</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="About">About</a>
                </li>
            </ul>

            <!-- RIGHT SIDE NAV LINKS -->
            <ul class="navbar-nav ms-auto">
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Manager</a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-area="ProductManagement" asp-controller="Category" asp-action="Manage">Manage Categories</a></li>
                            <li><a class="dropdown-item" asp-area="ProductManagement" asp-controller="Category" asp-action="Create">Create Category</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" asp-area="ProductManagement" asp-controller="Product" asp-action="Manage">Manage Products</a></li>
                            <li><a class="dropdown-item" asp-area="ProductManagement" asp-controller="Product" asp-action="Add">Add Product</a></li>
                            <li><a class="dropdown-item" asp-area="ProductManagement" asp-controller="Product" asp-action="LowStock">Low Stock</a></li>
                            <li><a class="dropdown-item" asp-area="ProductManagement" asp-controller="Order" asp-action="Index">Orders</a></li>
                        </ul>
                    </li>
                }

                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Admin</a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-area="Admin" asp-controller="User" asp-action="Index">View Users</a></li>
                        </ul>
                    </li>
                }

                @if (SignInManager.IsSignedIn(User))
                {
                    <li class="nav-item">
                        <a class="nav nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage your Profile">Profile</a>
                    </li>

                    <li class="nav-item">
                        <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                            <button type="submit" class="nav-link btn btn-link text-dark" style="cursor: pointer">Logout</button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav nav-link text-dark" asp-area="Identity" asp-page="/Account/Login" title="Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav nav-link text-dark" asp-area="Identity" asp-page="/Account/Register" title="Register">Register</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>
