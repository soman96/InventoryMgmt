@using InventoryMgmt.Areas.ProductManagement.Models
@model List<Product>

@inject SignInManager<IdentityUser> SignInManager

@{
    var products = Model ?? new List<Product>();
    var recentItems = products.OrderByDescending(p => p.ProductId).Take(4).ToList();
    var recentCategories = products.Select(p => p.Category).Where(c => c != null).Distinct().Take(4).ToList();
}

<div class="container my-4">

    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm">
        <div class="container-fluid py-5">
            <h1 class="display-5 fw-bold">Welcome to InventoryMgmt</h1>
            <p class="col-md-8 fs-5">Ultimate Inventory Management Solution</p>

            @if (!SignInManager.IsSignedIn(User))
            {
                <div class="mb-3">
                    <a class="btn btn-primary btn-lg me-2" asp-area="Identity" asp-page="/Account/Login">Login</a>
                    <a class="btn btn-outline-primary btn-lg" asp-area="Identity" asp-page="/Account/Register">Register</a>
                </div>

                <p class="text-muted">
                    Need a demo account? <a asp-area="" asp-controller="Home" asp-action="About">Head over to the About Us page</a>.
                </p>
            }

        </div>
    </div>


    @if (recentItems.Any())
    {
        <h3 class="mb-3">Recently Added Products</h3>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
            @foreach (var item in recentItems)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@item.ProductName</h5>
                            <p class="card-text text-muted">$@item.Price</p>
                            <p class="card-text small">Category: @item.Category?.Name</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (recentCategories.Any())
    {
        <h3 class="mt-5 mb-3">Recently Added Categories</h3>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
            @foreach (var cat in recentCategories)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@cat.Name</h5>
                            <p class="card-text text-muted">@cat.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>
