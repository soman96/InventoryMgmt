@model Product

@{
    ViewBag.Title = "Delete Product";
    Layout = "_Layout";
}

<h2>Are you sure you want to delete this project?</h2>


    <div class="container">
        <div class="row">
            <div class="col-md-12 mb-2">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@Model.ProductName</h5>
                        <p class="card-text">Price: @Model.Price.ToString("C")</p>
                        <p class="card-text">Stock: @Model.Quantity</p>

                        <form asp-action="Delete" method="post">
                            @Html.HiddenFor(model => Model.ProductId)
                            <input type="submit" value="Delete" class="btn btn-danger">
                            <a asp-action="Manage" class="btn btn-primary">Back to Manage Products</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    