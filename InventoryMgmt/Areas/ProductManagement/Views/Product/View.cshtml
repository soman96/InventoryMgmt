@model Product

@{
    ViewBag.Title = "Viewing Product";
    Layout = "_Layout";
}

<h2>Viewing @Model.ProductName</h2>

<div id="alert-container" class="mt-3"></div>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4 d-flex align-items-center">
            <img src="~/img/no-image.png" alt="Product Image" class="img-fluid rounded">
        </div>

        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body">
                    <h5 class="card-title">@Model.ProductName</h5>
                    <h6 class="card-subtitle mb-2 text-muted">Category: @Model.Category.Name</h6>
                    <p class="card-text">
                        Price: <strong>@Model.Price.ToString("C")</strong><br>
                        Quantity: <strong>@Model.Quantity</strong><br>
                        @* Low Stock Threshold: <strong>5</strong> *@
                    </p>
                    @if (@Model.Quantity == 0)
                    {
                        <a href="#" class="btn btn-success disabled">Add to Order</a>
                    }
                    else
                    {
                        <a href="#" class="btn btn-success add-to-cart" data-id="@Model.ProductId">Add to Order</a> 
                        @* <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@Model.ProductId" class="btn btn-success">Add to Order</a> *@
                    }
                    <a asp-action="Index" class="btn btn-primary">Return to Products</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).on('click', '.add-to-cart', function (e) {
        e.preventDefault();

        const productId = $(this).data('id');

        $('#alert-container').empty();
        $('#global-spinner').removeClass('d-none');

        setTimeout(() => {
            $.ajax({
                url: `/ProductManagement/Cart/AddToCart/${productId}`,
                method: 'GET',
                success: function (response) {
                    $('#alert-container').html(`
                        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                            ${response.message}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    `);
                },
                error: function () {
                    $('#alert-container').html(`
                        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                            Failed to add product to cart.
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    `);
                },
                complete: function () {
                    $('#global-spinner').addClass('d-none');
                }
            });
        }, 1000);
    });
</script>
}

