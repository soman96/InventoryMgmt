@model List<Category>

@{
    ViewBag.Title = "Categories";
    Layout = "_Layout";
}

<h2>Categories</h2>

@if (TempData["success"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["success"]
    </div>
}

@if (Model.Any())
{
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
        @foreach (var category in Model)
        {
            <div class="col">
                <a asp-area="ProductManagement"
                   asp-controller="Product"
                   asp-action="Index"
                   asp-route-categoryId="@category.CategoryId"
                   class="text-decoration-none text-dark">
                    <div class="card h-100 shadow-sm small-tile hover-shadow" style="cursor: pointer;">
                        <div class="card-body">
                            <h6 class="card-title fw-bold">@category.Name</h6>
                            <p class="card-text text-muted mb-1 small">@category.Description</p>
                            <p class="card-text text-secondary small mb-0">
                                <strong>@(category.Products?.Count ?? 0)</strong> product(s)
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
else
{
    <p>There are currently no categories to display.</p>
}